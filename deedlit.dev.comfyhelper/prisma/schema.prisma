// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model RootDirectory {
  id        String  @id
  path      String
  pathNorm  String  @unique @map("path_norm")
  createdAtMs Int   @map("created_at_ms")
  isVisible Boolean @default(true) @map("is_visible")

  @@map("root_directories")
}

model AppSetting {
  key       String @id
  value     String
  updatedAtMs Int  @map("updated_at_ms")

  @@map("app_settings")
}

model ImageCache {
  id               String  @id
  rootId           String  @map("root_id")
  rootPath         String  @map("root_path")
  absolutePath     String  @map("absolute_path")
  relativePath     String  @map("relative_path")
  fileName         String  @map("file_name")
  size             Int
  modifiedAtMs     Int     @map("modified_at_ms")
  modifiedAt       String  @map("modified_at")
  metadataPath     String? @map("metadata_path")
  metadataJson     String? @map("metadata_json")
  promptSummaryJson String? @map("prompt_summary_json")
  metadataError    String? @map("metadata_error")
  lastSeenJobId    String? @map("last_seen_job_id")
  createdAtMs      Int     @map("created_at_ms")
  updatedAtMs      Int     @map("updated_at_ms")

  @@index([rootId], map: "idx_image_cache_root")
  @@index([modifiedAtMs(sort: Desc)], map: "idx_image_cache_modified")
  @@map("image_cache")
}

model ScanJob {
  id             String  @id
  status         String
  totalFiles     Int     @default(0) @map("total_files")
  processedFiles Int     @default(0) @map("processed_files")
  cachedImages   Int     @default(0) @map("cached_images")
  warningsJson   String  @default("[]") @map("warnings_json")
  error          String?
  createdAtMs    Int     @map("created_at_ms")
  startedAtMs    Int?    @map("started_at_ms")
  finishedAtMs   Int?    @map("finished_at_ms")
  updatedAtMs    Int     @map("updated_at_ms")

  @@index([createdAtMs(sort: Desc)], map: "idx_scan_jobs_created")
  @@map("scan_jobs")
}

model PromptNote {
  id                 String  @id
  title              String
  positivePromptJson String  @default("{}") @map("positive_prompt_json")
  negativePromptJson String  @default("{}") @map("negative_prompt_json")
  notesJson          String  @default("{}") @map("notes_json")
  sortOrder          Int     @default(0) @map("sort_order")
  createdAtMs        Int     @map("created_at_ms")
  updatedAtMs        Int     @map("updated_at_ms")

  images PromptNoteImage[]

  @@index([sortOrder], map: "idx_prompt_notes_sort")
  @@index([updatedAtMs(sort: Desc)], map: "idx_prompt_notes_updated")
  @@map("prompt_notes")
}

model PromptNoteImage {
  id           String @id
  noteId       String @map("note_id")
  imageCacheId String @map("image_cache_id")
  sortOrder    Int    @default(0) @map("sort_order")
  addedAtMs    Int    @map("added_at_ms")

  note PromptNote @relation(fields: [noteId], references: [id], onDelete: Cascade)

  @@unique([noteId, imageCacheId], map: "uq_note_image")
  @@index([imageCacheId], map: "idx_prompt_note_images_cache_id")
  @@map("prompt_note_images")
}
