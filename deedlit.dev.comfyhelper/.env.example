# ===========================================================================
# Image-library stack configuration.
# Copy to .env.local for `next dev`, or rely on docker-compose env for the app.
# ===========================================================================

# --- deedlit.api BFF gateway: the ONLY backend comfyhelper talks to ---------
# comfyhelper is UI-only — every read/write goes through this single gateway,
# which fans out to catalog/search/graph/ingest. Point it at the running
# deedlit.api instance (local dev default below).
DEEDLIT_API_URL=http://localhost:8088

# Base URL for image blob bytes (thumbnails / originals). The gateway proxies
# catalog blobs at /blobs/{sha256}/{kind}, so this defaults to DEEDLIT_API_URL
# when unset. Override only to hit the catalog directly (e.g. http://localhost:8001).
# DEEDLIT_BLOB_URL=http://localhost:8088

# Redis image-bytes cache. When set, thumbnail/file proxy routes serve bytes
# from Redis before hitting the blob service. On a thumbnail miss, the original
# is also fetched and cached in the background (eager warm). Unset = no caching.
REDIS_URL=redis://localhost:6379

# ---------------------------------------------------------------------------
# The vars below are consumed by the BACKEND services (catalog/search/graph/
# ingest/vision/metadata), NOT by comfyhelper. Kept here for a single-file dev
# reference; comfyhelper itself only needs DEEDLIT_API_URL above.
# ===========================================================================

# --- PostgreSQL: canonical source of truth ---------------------------------
DATABASE_URL=postgresql://imageapp:imageapp@localhost:5432/imageapp

# --- Neo4j: relationship graph projection ----------------------------------
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# --- Qdrant: vector similarity projection ----------------------------------
QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=
QDRANT_COLLECTION=images

# Browser-reachable base URL of this comfyhelper instance (no trailing slash).
# Baked into the Qdrant payload as absolute proxy URLs (thumbnail_url/image_url)
# so images render in the Qdrant dashboard / deedlit.vision test UI instead of
# pointing at an unreachable server-local file_path. Must be the address your
# browser uses to reach comfyhelper (e.g. http://localhost:3000), not an
# in-network docker hostname.
COMFYHELPER_PUBLIC_URL=http://localhost:3000

# --- Local image storage ---------------------------------------------------
IMAGE_LIBRARY_ROOT=D:/images/generated
THUMBNAIL_ROOT=D:/images/thumbnails

# --- deedlit.metadata extraction API (PNG metadata parsing) ----------------
# Stateless service that parses embedded PNG metadata (A1111 `parameters` blob /
# ComfyUI node graph) into typed fields. Ingest sends image bytes here instead
# of parsing in-process. Local dev default is http://localhost:8005; in compose
# it is the in-network service hostname.
METADATA_API_URL=http://localhost:8005

# --- deedlit.vision CLIP embedding API (image similarity / semantic search) -
# Point to a running deedlit.vision instance. REQUIRED: image and text
# embeddings are generated exclusively by the external CLIP model — there is no
# local fallback. If unset/unreachable, ingest and similarity search error
# instead of silently degrading.
CLIP_VISION_API_URL=http://localhost:8000

# Embedding vector dimension — must match the CLIP model preset:
#   1024  → vit_h  (default, lighter)
#   1280  → big_g  (heavier, higher quality)
#    512  → local pixel-histogram fallback (no deedlit.vision)
# Changing this after images have been indexed requires a Qdrant rebuild:
#   POST /api/library/maintenance/rebuild-qdrant
EMBEDDING_DIMENSIONS=1024

# --- Optional external vision / LLM enrichment (off by default) ------------
ENABLE_EXTERNAL_VISION_ENRICHMENT=false
EXTERNAL_VISION_PROVIDER=none
EXTERNAL_VISION_API_URL=
EXTERNAL_VISION_API_KEY=
EXTERNAL_VISION_MODEL=
EXTERNAL_TEXT_EMBEDDING_PROVIDER=local
EXTERNAL_IMAGE_EMBEDDING_PROVIDER=local

# --- MCP tool surface ------------------------------------------------------
MCP_ENABLED=true

# --- RustFS / S3 object storage (thumbnails + cached embeddings) -----------
# When disabled, thumbnails go to THUMBNAIL_ROOT on local disk and embeddings
# are recomputed each time instead of cached.
OBJECT_STORE_ENABLED=true
OBJECT_STORE_ENDPOINT=http://localhost:9000
OBJECT_STORE_REGION=us-east-1
OBJECT_STORE_ACCESS_KEY=rustfsadmin
OBJECT_STORE_SECRET_KEY=rustfsadmin
OBJECT_STORE_BUCKET=comfyhelper
OBJECT_STORE_FORCE_PATH_STYLE=true

# --- OpenTelemetry tracing (instrumentation.ts -> Tempo) -------------------
# When OTEL_EXPORTER_OTLP_ENDPOINT is set, @vercel/otel exports spans over
# OTLP/http. Point it at the Tempo OTLP receiver: the host-mapped port (4318)
# for `next dev`, or http://tempo:4318 when running inside docker-compose.
# Leave unset to disable tracing entirely (no-op exporter).
OTEL_SERVICE_NAME=comfyhelper
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf

# In docker-compose the Python services trace automatically (the
# opentelemetry-instrument entrypoint + OTEL_* env wired per service). To ALSO
# trace them under `npm run dev` (bare uvicorn), export OTEL_TRACES_EXPORTER=otlp
# in the shell before starting — each service self-instruments at import via the
# guard in its app.py and exports to OTEL_EXPORTER_OTLP_ENDPOINT (host 4318).
# OTEL_TRACES_EXPORTER=otlp
