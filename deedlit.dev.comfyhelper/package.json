{
  "name": "deedlit.dev.comfyhelper",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "postinstall": "prisma generate",
    "build:ui": "npm run build --prefix ../deedlit.dev.ui",
    "dev": "next dev",
    "build": "npm run build:ui && prisma generate && next build",
    "postbuild": "node ./scripts/prepare-standalone.mjs",
    "start": "next start",
    "lint": "eslint",
    "test:unit": "playwright test -c playwright.unit.config.ts",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report"
  },
  "dependencies": {
    "@deedlit.dev/ui": "file:../deedlit.dev.ui",
    "@editorjs/code": "^2.9.4",
    "@editorjs/editorjs": "^2.31.3",
    "@editorjs/header": "^2.8.8",
    "@editorjs/list": "^2.0.9",
    "@editorjs/paragraph": "^2.11.7",
    "@prisma/adapter-better-sqlite3": "^7.4.0",
    "@prisma/client": "^7.4.0",
    "@tanstack/react-query": "^5.90.21",
    "clsx": "^2.1.1",
    "jotai": "^2.18.0",
    "next": "16.1.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-icons": "^5.5.0",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^25",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^10.0.0",
    "eslint-config-next": "^16.1.6",
    "playwright": "^1.58.2",
    "prisma": "^7.4.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}

