OTEL_SERVICE_NAME=deedlit.vision
OTEL_TRACES_EXPORTER=otlp
OTEL_METRICS_EXPORTER=none
OTEL_LOGS_EXPORTER=none
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf

# Pin to the single smaller CLIP tower. Unset, CLIP_MODELS defaults to
# "vit_h,big_g", leaving the 3.7 GB big_g tower loadable on request — which on a
# tight box exhausts VRAM / Windows commit ("paging file too small", os 1455).
CLIP_MODEL_PRESET=vit_h
CLIP_MODELS=vit_h
