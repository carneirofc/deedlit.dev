OTEL_SERVICE_NAME=deedlit.ingest
OTEL_TRACES_EXPORTER=otlp
OTEL_METRICS_EXPORTER=none
OTEL_LOGS_EXPORTER=none
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf

# Optional AI labeling enrichment. Unset => describe_image() short-circuits and
# the labelagent (and its llama-server) is never called. Point at the local
# labelagent (npm run dev:labelagent -> :8006), which in turn calls llama-server.
LABELAGENT_URL=http://127.0.0.1:8006

# Background schedulers (seconds; 0/unset disables). FOLDER_SCAN re-walks the
# configured-folder registry (catalog /folders) on each folder's own interval;
# LABEL_BACKFILL periodically relabels images missing an AI description. The
# scheduler reads/writes catalog at CATALOG_URL (default http://localhost:8001).
FOLDER_SCAN_TICK_SECONDS=60
LABEL_BACKFILL_INTERVAL_SECONDS=0
