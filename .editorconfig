# EditorConfig — consistent style across editors. https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# Python (deedlit.vision) uses 4-space indentation.
[*.py]
indent_size = 4

# Keep trailing whitespace in Markdown (hard line breaks).
[*.md]
trim_trailing_whitespace = false

# Windows-native scripts use CRLF.
[*.{bat,cmd}]
end_of_line = crlf

[Makefile]
indent_style = tab
