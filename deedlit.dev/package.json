{
  "name": "deedlit.dev",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build:ui": "npm run build --prefix ../deedlit.dev.ui",
    "dev": "next dev -p 3001",
    "build": "npm run build:ui && next build",
    "postbuild": "node scripts/copy-next-static.js",
    "start": "cross-env PORT=3001 node .next/standalone/deedlit.dev/server.js",
    "lint": "next lint",
    "scrape-goodreads": "tsx scripts/scrape-goodreads.ts",
    "playwright-examples": "tsx scripts/playwright-examples.ts",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@deedlit.dev/ui": "file:../deedlit.dev.ui",
    "clsx": "^2.1.1",
    "next": "^16.1.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-icons": "^5.5.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.2.0",
    "@types/node": "^25.3.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "autoprefixer": "10.4.24",
    "cross-env": "^10.1.0",
    "eslint": "^10.0.0",
    "eslint-config-next": "^16.1.6",
    "playwright": "^1.58.2",
    "postcss": "8.5.6",
    "tailwindcss": "4.2.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "5.9.3"
  }
}

