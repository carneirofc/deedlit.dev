{
  "name": "deedlit.dev-workspace",
  "version": "1.1.0",
  "private": true,
  "workspaces": [
    "deedlit.dev.ui",
    "deedlit.dev",
    "deedlit.dev.comfyhelper"
  ],
  "scripts": {
    "dev": "mprocs",
    "build:ui": "npm run build -w @carneirofc/ui",
    "build:dev": "npm run build:ui && npm run build -w deedlit.dev",
    "build:comfyhelper": "npm run build:ui && npm run build -w deedlit.dev.comfyhelper",
    "build": "npm run build:ui && npm run build -w deedlit.dev && npm run build -w deedlit.dev.comfyhelper",
    "dev:dev": "npm run dev -w deedlit.dev",
    "dev:comfyhelper": "npm run dev -w deedlit.dev.comfyhelper",
    "dev:vision": "uv run --directory deedlit.vision --env-file .env uvicorn app:app --host 127.0.0.1 --port 8000",
    "dev:catalog": "uv run --directory deedlit.catalog --env-file .env uvicorn app:app --host 127.0.0.1 --port 8001",
    "dev:search": "uv run --directory deedlit.search --env-file .env uvicorn app:app --host 127.0.0.1 --port 8002",
    "dev:graph": "uv run --directory deedlit.graph --env-file .env uvicorn app:app --host 127.0.0.1 --port 8003",
    "dev:ingest": "uv run --directory deedlit.ingest --env-file .env uvicorn app:app --host 127.0.0.1 --port 8004",
    "dev:ingest-worker": "uv run --directory deedlit.ingest --env-file .env python worker.py",
    "dev:metadata": "uv run --directory deedlit.metadata --env-file .env uvicorn app:app --host 127.0.0.1 --port 8005",
    "dev:labelagent": "uv run --directory deedlit.labelagent --env-file .env uvicorn app:app --host 127.0.0.1 --port 8006",
    "dev:api": "uv run --directory deedlit.api --env-file .env uvicorn app:app --host 127.0.0.1 --port 8088",
    "dev:migrate": "uv run --directory deedlit.catalog python -m catalog.migrations",
    "predev": "npm run infra:up && npm run dev:migrate",
    "predev:services": "npm run infra:up && npm run dev:migrate",
    "dev:services": "concurrently -k -p \"[{name}]\" -n vision,catalog,search,graph,ingest,metadata,labelagent,api -c blue,green,magenta,yellow,cyan,red,gray,white \"npm:dev:vision\" \"npm:dev:catalog\" \"npm:dev:search\" \"npm:dev:graph\" \"npm:dev:ingest\" \"npm:dev:metadata\" \"npm:dev:labelagent\" \"npm:dev:api\"",
    "dev:web": "concurrently -k -p \"[{name}]\" -n dev,comfyhelper -c gray,cyan \"npm:dev:dev\" \"npm:dev:comfyhelper\"",
    "infra:up": "docker compose up -d --wait postgres neo4j qdrant rustfs rabbitmq redis tempo loki alloy grafana",
    "infra:down": "docker compose down",
    "infra:stop": "docker compose stop postgres neo4j qdrant rustfs rabbitmq redis tempo loki alloy grafana",
    "infra:restart": "docker compose restart postgres neo4j qdrant rustfs rabbitmq redis tempo loki alloy grafana",
    "infra:ps": "docker compose ps postgres neo4j qdrant rustfs rabbitmq redis tempo loki alloy grafana",
    "infra:logs": "docker compose logs -f postgres neo4j qdrant rustfs rabbitmq redis tempo loki alloy grafana",
    "start:dev": "npm run start -w deedlit.dev",
    "start:comfyhelper": "npm run start -w deedlit.dev.comfyhelper",
    "start:vision": "uv run --directory deedlit.vision --env-file .env uvicorn app:app --host 127.0.0.1 --port 8000",
    "start:catalog": "uv run --directory deedlit.catalog --env-file .env uvicorn app:app --host 127.0.0.1 --port 8001",
    "start:search": "uv run --directory deedlit.search --env-file .env uvicorn app:app --host 127.0.0.1 --port 8002",
    "start:graph": "uv run --directory deedlit.graph --env-file .env uvicorn app:app --host 127.0.0.1 --port 8003",
    "start:ingest": "uv run --directory deedlit.ingest --env-file .env uvicorn app:app --host 127.0.0.1 --port 8004",
    "start:ingest-worker": "uv run --directory deedlit.ingest --env-file .env python worker.py",
    "start:metadata": "uv run --directory deedlit.metadata --env-file .env uvicorn app:app --host 127.0.0.1 --port 8005",
    "start:labelagent": "uv run --directory deedlit.labelagent --env-file .env uvicorn app:app --host 127.0.0.1 --port 8006",
    "start:api": "uv run --directory deedlit.api --env-file .env uvicorn app:app --host 0.0.0.0 --port 8088",
    "prod:infra": "npm run infra:up && npm run dev:migrate",
    "prod:build": "npm run build",
    "prod": "mprocs --config mprocs.prod.yaml",
    "prod:all": "npm run prod:infra && npm run prod:build && npm run prod"
  },
  "devDependencies": {
    "concurrently": "^10.0.3"
  }
}
