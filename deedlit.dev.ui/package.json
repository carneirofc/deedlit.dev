{
  "name": "@carneirofc/ui",
  "version": "1.0.0",
  "description": "App-agnostic UI building blocks and shared visual system for deedlit.dev.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/carneirofc/deedlit.dev.git",
    "directory": "deedlit.dev.ui"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "files": [
    "dist",
    "styles/styles.css",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node ./scripts/fix-esm-imports.mjs",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "sideEffects": [
    "./styles/styles.css"
  ],
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./styles.css": {
      "default": "./styles/styles.css"
    }
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "radix-ui": "^1.6.1",
    "tailwind-merge": "^3.5.0"
  },
  "peerDependencies": {
    "react": "^19",
    "react-dom": "^19"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^10.4.6",
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/react-vite": "^10.4.6",
    "@tailwindcss/vite": "^4.3.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "storybook": "^10.4.6",
    "typescript": "^5.9.3",
    "vite": "^8.1.0"
  }
}
